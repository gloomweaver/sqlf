{
  "name": "@effql/example-basic",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:start": "docker compose up -d --wait",
    "db:stop": "docker compose down -v",
    "generate": "docker compose up -d --wait && node ../../packages/cli/dist/index.mjs generate --config ./effql.config.ts",
    "start": "docker compose up -d --wait && node --experimental-strip-types ./src/server.ts"
  },
  "dependencies": {
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effql/core": "workspace:*",
    "effect": "catalog:",
    "effql": "workspace:*",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
