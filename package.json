{
  "name": "effql-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "sqlc-style TypeScript code generation for Effect SQL using Postgres introspection",
  "keywords": [
    "codegen",
    "dx",
    "effect-ts",
    "postgres",
    "sql",
    "sqlc",
    "typescript"
  ],
  "homepage": "https://github.com/gloomweaver/effql#readme",
  "bugs": {
    "url": "https://github.com/gloomweaver/effql/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gloomweaver/effql.git"
  },
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "test": "vp run -r test",
    "check": "vp check && vp run -r test && vp run -r build",
    "ready": "vp fmt && vp lint && vp run -r test && vp run -r build",
    "example:smoke": "bash ./scripts/smoke-example.sh"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
