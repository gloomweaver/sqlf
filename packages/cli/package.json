{
  "name": "@effql/cli",
  "version": "0.1.0",
  "description": "sqlc-style TypeScript code generation for Effect SQL using Postgres introspection",
  "keywords": [
    "codegen",
    "effect-ts",
    "postgres",
    "sql",
    "sqlc",
    "typescript"
  ],
  "homepage": "https://github.com/gloomweaver/effql#readme",
  "bugs": {
    "url": "https://github.com/gloomweaver/effql/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gloomweaver/effql.git",
    "directory": "packages/cli"
  },
  "bin": {
    "effql": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@effql/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
